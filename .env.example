# ================================================================
# Avakanta Backend — Variables de entorno de producción
# Copiar a .env y rellenar los valores reales.
# NUNCA commitear el .env al repositorio.
#
# Generar SECRET_KEY:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# ================================================================

# Django
SECRET_KEY=CAMBIAR-genera-con-get_random_secret_key
DEBUG=False
ALLOWED_HOSTS=api.tudominio.com,localhost,127.0.0.1
BACKEND_URL=https://api.tudominio.com

# PostgreSQL
# IMPORTANTE: DATABASE_URL la construye docker-compose usando "db" como hostname.
# No definir DATABASE_URL aquí — el compose la arma automáticamente con las vars de abajo.
POSTGRES_DB=avakanta_db
POSTGRES_USER=avakanta
POSTGRES_PASSWORD=CAMBIAR-password-seguro-y-largo

# CORS — URL exacta del frontend en Vercel (sin trailing slash)
CORS_ALLOWED_ORIGINS=https://tu-proyecto.vercel.app

# Gunicorn
# Cambiar GUNICORN_PORT si hay conflicto con otros proyectos en el VPS
GUNICORN_PORT=8000
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# Email transaccional (para OTPs y notificaciones a usuarios)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.tuproveedor.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@tudominio.com
EMAIL_HOST_PASSWORD=CAMBIAR-password-smtp
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Avakanta <noreply@tudominio.com>

# Google OAuth
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
